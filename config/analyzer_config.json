{
  "version": "1.0.0",
  "analyzers": {
    "python": {
      "enabled": true,
      "timeout": 30,
      "max_file_size": 10485760
    },
    "java": {
      "enabled": true,
      "timeout": 30,
      "max_file_size": 10485760
    },
    "cpp": {
      "enabled": true,
      "timeout": 30,
      "max_file_size": 10485760
    },
    "javascript": {
      "enabled": true,
      "timeout": 30,
      "max_file_size": 10485760
    }
  },
  "output": {
    "default_format": "table",
    "colors_enabled": true,
    "verbose": false
  },
  "limits": {
    "max_loop_depth": 10,
    "max_recursion_depth": 1000,
    "complexity_timeout": 60
  }
}